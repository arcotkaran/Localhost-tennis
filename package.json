{
  "name": "local-tennis",
  "version": "1.0.0",
  "description": "Zero-lag local multiplayer tennis platform. Host renders on TV, phones are controllers over local Wi-Fi.",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "test": "node --test \"tests/*.test.js\"",
    "test:phase1": "node --test tests/phase1.network.test.js",
    "test:phase2": "node --test tests/phase2.controller.test.js",
    "test:phase3": "node --test tests/phase3.physics.test.js",
    "test:phase4": "node --test tests/phase4.gameloop.test.js",
    "test:phase5": "node --test tests/phase5.performance.test.js",
    "test:phase6": "node --test tests/phase6.tournament.test.js",
    "test:phase7": "node --test tests/phase7.integration.test.js",
    "test:phase8": "node --test tests/phase8.session.test.js",
    "test:phase9": "node --test tests/phase9.polish.test.js",
    "test:phase10": "node --test tests/phase10.experience.test.js",
    "test:phase11": "node --test tests/phase11.hardening.test.js",
    "test:phase12": "node --test tests/phase12.gameplay.test.js",
    "test:phase13": "node --test tests/phase13.shipprep.test.js",
    "test:phase14": "node --test tests/phase14.controls.test.js",
    "test:phase15": "node --test tests/phase15.realmatch.test.js"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
